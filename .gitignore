node_modules/
dist/
/build/
.next/
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Large / generated assets (keep source, ignore heavy exports)
*.mp4
*.mov
!resources/**
/models/
*.gguf
*.safetensors
*.bin

