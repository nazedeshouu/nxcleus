.ruff_cache/

# Runtime state (SQLite ledger, packages, workspaces) — regenerated by the control plane
/data/
backend/data/

# Generated seed databases (regenerated by infra/seeds/*.py; 300MB+, keep the small fixtures)
infra/seeds/out/*.db

