# Nxcleus local development defaults. Copy this file to .env and change only what you need.

# Deterministic, offline routing for local development and CI.
MODEL_MODE=mock
APP_BASE_URL=http://localhost:5173

# Local persistence and tracked routing configuration.
SQLITE_PATH=./data/platform.db
DATA_DIR=./data
SEATS_CONFIG=infra/seats.yaml
MODELS_CONFIG=infra/models.yaml
FLEET_CONFIG=infra/fleet.yaml
RATES_CONFIG=infra/rates.yaml
CODEEXEC_IMAGE=nxcleus/codeexec:py312

# Fail-closed defaults. Enable both demo escape hatches only for an intentional local demo.
UNSAFE_DEMO_RUNTIME=false
ALLOW_UNVERIFIED_DEMO_DELIVERY=false
ALLOW_RAW_ON_AMD_HOSTED=false
SOVEREIGN_DEFAULT=false
TRACE_PROMPTS=false

# Shared deployments should configure cookie-session auth.
AUTH_ADMIN_PASSWORD=
AUTH_JUDGE_PASSWORD=
AUTH_SECRET=
AUTH_SIGNUP_CODE=

# Legacy presenter/admin token. Leave empty only for private local development.
ADMIN_TOKEN=

# Provider credentials are unused in MODEL_MODE=mock. Never commit real values.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference
HF_TOKEN=
HF_TOKEN_FILE=
DIGITALOCEAN_ACCESS_TOKEN=

# Optional local integrations.
WHISPER_MODEL_PATH=
FERNET_KEY=
DISCORD_WEBHOOK_URL=
