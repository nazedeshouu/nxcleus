# Caddy reverse proxy (01 §5). Auto-HTTPS on ALL site hostnames. NXCLEUS_SITE is a comma-separated
# list of hostnames (deploy.sh composes it: primary domain + the sslip host so the old URL never
# breaks). Each host gets its own Let's Encrypt cert automatically.
# / -> frontend static, /api -> uvicorn, /processes/{slug} -> runtime containers.

{$NXCLEUS_SITE:localhost} {
	encode zstd gzip

	# API + SSE (disable buffering so events stream promptly)
	handle /api/* {
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}
	handle /openapi.json {
		reverse_proxy api:8000
	}
	handle /docs* {
		reverse_proxy api:8000
	}

	# process-runtime containers, exposed read-only for inspector probes + judges (04 §3)
	handle /processes/* {
		reverse_proxy api:8000
	}

	# frontend static build (../../frontend/dist mounted at /srv/www). SPA fallback to index.html
	# so client-side routes (react-router) deep-link correctly; unknown asset paths 404 normally.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}

	# never cache the SPA entry document (assets are content-hashed and cached by default)
	@html path / /index.html
	header @html Cache-Control "no-cache"
}
